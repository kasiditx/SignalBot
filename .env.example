TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SIGNAL_SYMBOL=XAUUSD
SIGNAL_TIMEFRAME=M5
SIGNAL_CSV_PATH=samples/ohlcv_sample.csv
SIGNAL_TRADE_MODE=high_winrate
SIGNAL_MULTI_TIMEFRAME=false
SIGNAL_CSV_PATH_D1=
SIGNAL_CSV_PATH_H4=
SIGNAL_CSV_PATH_H1=
SIGNAL_CSV_PATH_M30=
SIGNAL_CSV_PATH_M15=
SIGNAL_CSV_PATH_M5=

SIGNAL_FAST_EMA=12
SIGNAL_SLOW_EMA=26
SIGNAL_RSI_PERIOD=14
SIGNAL_ATR_PERIOD=14
SIGNAL_ATR_MULTIPLIER=1.5
SIGNAL_BODY_BREAK_ATR_RATIO=0.20
SIGNAL_RISK_REWARD=0.7
SIGNAL_MIN_CANDLES=60
SIGNAL_MAX_CANDLE_AGE_MINUTES=180

# true = print message only, false = send to Telegram.
SIGNAL_DRY_RUN=true

# false = do not send WAIT/no-trade messages to Telegram.
SIGNAL_SEND_WAIT=false
SIGNAL_POLL_SECONDS=5
SIGNAL_STALE_LOG_SECONDS=300
SIGNAL_ERROR_LOG_SECONDS=60
SIGNAL_ALLOW_MARKET_CLOSED_STALE=true
SIGNAL_MARKET_CLOSED_STALE_HOURS=72
SIGNAL_STATE_PATH=logs/signal_poller_state.json
SIGNAL_LOG_STATE_PATH=logs/signal_poller_log_state.json
SIGNAL_SEND_CHART=true
SIGNAL_CHART_PATH=logs/latest_signal_chart.png

# Auto trade is disabled by default. Start with paper mode, then MT5 EA DryRun.
AUTO_TRADE_ENABLED=false
AUTO_TRADE_MODE=paper
AUTO_TRADE_ORDER_FILE=logs/trading_signal_order.csv
AUTO_TRADE_JOURNAL_FILE=logs/auto_trade_journal.csv
AUTO_TRADE_ACCOUNT_BALANCE=30
AUTO_TRADE_RISK_PERCENT=0.5
AUTO_TRADE_CONTRACT_SIZE=100
AUTO_TRADE_MIN_VOLUME=0.01
AUTO_TRADE_MAX_VOLUME=0.01
AUTO_TRADE_VOLUME_STEP=0.01
AUTO_TRADE_ALLOW_MIN_VOLUME=false
AUTO_TRADE_MAGIC_NUMBER=20260515
AUTO_TRADE_COMMENT=TradingSignalBot

# TradingView webhook -> Telegram
TRADINGVIEW_WEBHOOK_SECRET=change-me
TRADINGVIEW_WEBHOOK_HOST=127.0.0.1
TRADINGVIEW_WEBHOOK_PORT=8080
TRADINGVIEW_WEBHOOK_PATH=/webhook
TRADINGVIEW_WEBHOOK_DRY_RUN=true

# Optional MT5 CSV exporter. Requires MetaTrader5 package and an installed MT5 terminal.
MT5_SYMBOL=XAUUSD
MT5_TIMEFRAME=M5
MT5_BARS=27000
MT5_OUTPUT_CSV=data/mt5_ohlcv.csv

# Backtest range. Empty = all available data, 30 = latest 30 calendar days.
BACKTEST_LOOKBACK_DAYS=
BACKTEST_INITIAL_BALANCE=30
BACKTEST_RISK_PERCENT=0.5
BACKTEST_CONTRACT_SIZE=100
BACKTEST_MIN_VOLUME=0.01
BACKTEST_MAX_VOLUME=0.01
BACKTEST_VOLUME_STEP=0.01
BACKTEST_COMPOUND=true
BACKTEST_ALLOW_MIN_VOLUME=true
BACKTEST_STOP_ON_ZERO_BALANCE=true
